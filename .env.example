APP_PORT=5000
APP_SECRET_KEY=replace-with-a-long-random-secret
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=replace-with-a-strong-password
VIDEOBOT_DATA_DIR=/opt/videobot-data
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=
VIDEOBOT_RUN_EMBEDDED_SCHEDULER=false

# Opcional: claves de proveedores externas.
DEFAULT_PEXELS_API_KEY=
PIXABAY_API_KEY=
DEFAULT_ELEVEN_API_KEY=
DEFAULT_ELEVEN_VOICE_ID=

# Opcional: paths locales para OAuth de YouTube.
GOOGLE_CLIENT_SECRET_PATH=/secure/client_secret.json
YOUTUBE_TOKEN_OUTPUT_PATH=/secure/token.pickle
